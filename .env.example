OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
GROK_API_KEY=...

# Optional overrides
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-5.5
# MODEL_REASONING_EFFORT=medium
# MODEL_BASE_URL=http://localhost:1234/v1
# MODEL_AUTH_FILE=~/.codex/auth.json
# MODEL_TIMEOUT_SECONDS=180
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=local-hash-embedding
# EXECUTIONER_BIN=../substrate/target/debug/executioner

# Gemini uses Google's OpenAI-compatible endpoint automatically when
# MODEL_PROVIDER=gemini and MODEL_BASE_URL is unset.
# MODEL_PROVIDER=gemini
# MODEL_NAME=gemini-3.1-flash-lite

# Grok uses LangChain's first-class xAI integration automatically when
# MODEL_PROVIDER=xai or MODEL_PROVIDER=grok. XAI_API_KEY is also accepted.
# MODEL_PROVIDER=xai
# MODEL_NAME=grok-4.3
