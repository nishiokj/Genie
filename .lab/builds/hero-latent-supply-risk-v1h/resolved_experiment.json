{
  "experiment": {
    "description": "Bucephalus runs Nova over a small, curated Genie-seeded latent supply-risk corpus. The paired variants test whether an evidence-first configuration improves detection of world-event-to-enterprise-exposure chains while preserving no-alert restraint.",
    "id": "hero_latent_supply_risk_v1_nova",
    "name": "Hero Latent Supply Risk v1: Nova Variant Experiment",
    "tags": [
      "hero-demo",
      "latent-supply-risk",
      "nova",
      "genie",
      "substrate",
      "paired-variants"
    ]
  },
  "matrix": {
    "repeats": 1,
    "seeds": [
      20260527
    ],
    "tasks": {
      "path": "tasks/tasks.jsonl",
      "source": "file"
    },
    "variants": [
      {
        "baseline": true,
        "config": {
          "mode": "baseline",
          "model": "gpt-5.4",
          "model_provider": "codex",
          "reasoning": "medium"
        },
        "id": "baseline"
      },
      {
        "config": {
          "mode": "evidence_first",
          "model": "gpt-5.4",
          "model_provider": "codex",
          "reasoning": "medium"
        },
        "id": "evidence_first"
      }
    ]
  },
  "metrics": [
    {
      "direction": "maximize",
      "id": "pass_rate",
      "label": "Pass Rate",
      "primary": true,
      "source": {
        "output": "grade",
        "pointer": "/passed",
        "type": "grader_output"
      }
    },
    {
      "direction": "maximize",
      "id": "score",
      "label": "Evidence-Weighted Score",
      "source": {
        "output": "grade",
        "pointer": "/score",
        "type": "grader_output"
      }
    },
    {
      "direction": "minimize",
      "id": "false_positive_count",
      "label": "False Positive Count",
      "source": {
        "output": "grade",
        "pointer": "/false_positive_count",
        "type": "grader_output"
      }
    }
  ],
  "policy": {
    "sanitization_profile": "perf_benchmark",
    "task_sandbox": {},
    "timeout_ms": 960000
  },
  "runtime": {
    "compute": {
      "backend": "local-docker"
    },
    "network": {
      "agent": "full",
      "task_sandbox": "none"
    },
    "storage": {
      "backend": "local-fs",
      "config": {
        "root": ".lab/runs/"
      }
    },
    "traces": {
      "backend": "local-stdout"
    }
  },
  "scheduling": {
    "comparison": "paired",
    "max_concurrency": 2,
    "random_seed": 20260527,
    "shuffle_tasks": false
  },
  "trial_runtime": {
    "agent": {
      "command": [
        "python3",
        "__BUCEPHALUS_TASK_WORKDIR__/.bucephalus/support/run_nova_latent_supply_risk.py",
        "--mode",
        "$mode",
        "--provider",
        "$model_provider",
        "--model",
        "$model",
        "--reasoning",
        "$reasoning"
      ],
      "events": [
        {
          "format": "jsonl",
          "id": "nova_events",
          "ingest": true,
          "mode": "jsonl",
          "path": "/bucephalus/out/nova-events.jsonl",
          "retain_raw": true
        }
      ],
      "integration_level": "cli_events",
      "outputs": {
        "result": {
          "capture": {
            "format": "json",
            "path": "/bucephalus/out/result.json",
            "required": true,
            "type": "file"
          }
        },
        "trajectory": {
          "capture": {
            "format": "text",
            "path": "/bucephalus/out/nova-events.jsonl",
            "required": false,
            "type": "file"
          }
        }
      }
    },
    "execution": {
      "agent_site": "host"
    },
    "grader": {
      "command": [
        "python3",
        "__BUCEPHALUS_TASK_WORKDIR__/.bucephalus/support/grade_latent_supply_risk_inline.py"
      ],
      "inputs": {
        "case_id": {
          "materialize": {
            "as": "file",
            "path": "/grader/in/case_id.txt"
          },
          "required": true,
          "source": {
            "case": "id"
          }
        },
        "result": {
          "materialize": {
            "as": "file",
            "path": "/grader/in/result.json"
          },
          "required": true,
          "source": {
            "output": "agent.result"
          }
        }
      },
      "outputs": {
        "grade": {
          "capture": {
            "format": "json",
            "path": "/grader/out/latent-supply-risk-grade.json",
            "required": true,
            "type": "file"
          }
        }
      },
      "strategy": "in_task_runtime"
    },
    "task": {
      "interface": "writable_workspace",
      "workspace": {
        "image": {
          "from": "case_row"
        },
        "source": "container_image",
        "workdir": {
          "from": "case_row"
        }
      }
    }
  }
}